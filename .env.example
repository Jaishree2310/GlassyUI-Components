# Frontend (Create React App) — copy to .env.local for local development
REACT_APP_API_URL=http://localhost:5000

# Firebase (create your own project at https://console.firebase.google.com)
# Do not commit real values. Required only if you enable auth routes.
REACT_APP_FIREBASE_API_KEY=
REACT_APP_FIREBASE_AUTH_DOMAIN=
REACT_APP_FIREBASE_PROJECT_ID=
REACT_APP_FIREBASE_STORAGE_BUCKET=
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=
REACT_APP_FIREBASE_APP_ID=
REACT_APP_FIREBASE_MEASUREMENT_ID=

# Optional: must match server STORIES_API_KEY when story writes are protected
REACT_APP_STORIES_API_KEY=
